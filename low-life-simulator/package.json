{
  "name": "low-life-simulator",
  "displayName": "低配人生：工位模拟器",
  "description": "A tiny workday text simulator hidden in the VS Code sidebar.",
  "version": "0.3.3",
  "publisher": "LifesimPress",
  "license": "MIT",
  "icon": "media/marketplace-icon.png",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "game",
    "sidebar",
    "text-game",
    "simulator",
    "workday"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "onView:lifesimpress-low-life-simulator-sidebar",
    "onCommand:lifesimpress.lowLifeSimulator.open",
    "onCommand:lifesimpress.lowLifeSimulator.startDay",
    "onCommand:lifesimpress.lowLifeSimulator.reset",
    "onCommand:lifesimpress.lowLifeSimulator.setApiKey",
    "onCommand:lifesimpress.lowLifeSimulator.clearApiKey"
  ],
  "main": "./extension.js",
  "scripts": {
    "check": "node --check extension.js"
  },
  "contributes": {
    "commands": [
      {
        "command": "lifesimpress.lowLifeSimulator.open",
        "title": "低配人生: 打开侧边栏"
      },
      {
        "command": "lifesimpress.lowLifeSimulator.startDay",
        "title": "低配人生: 开始新的一天"
      },
      {
        "command": "lifesimpress.lowLifeSimulator.reset",
        "title": "低配人生: 重置存档"
      },
      {
        "command": "lifesimpress.lowLifeSimulator.setApiKey",
        "title": "低配人生: 设置 MiniMax API Key"
      },
      {
        "command": "lifesimpress.lowLifeSimulator.clearApiKey",
        "title": "低配人生: 清除 MiniMax API Key"
      }
    ],
    "configuration": {
      "title": "低配人生",
      "properties": {
        "lifesimpress.lowLifeSimulator.minimaxBaseUrl": {
          "type": "string",
          "default": "https://api.minimax.io/v1",
          "description": "MiniMax OpenAI-compatible base URL. 国内用户可按 MiniMax 控制台说明改为 https://api.minimaxi.com/v1。"
        },
        "lifesimpress.lowLifeSimulator.minimaxModel": {
          "type": "string",
          "default": "MiniMax-M2.7-highspeed",
          "description": "用于 AI 模式自动生成随机事件的 MiniMax 模型。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "lifesimpress-low-life-simulator",
          "title": "低配人生",
          "icon": "media/icon.svg"
        }
      ]
    },
    "views": {
      "lifesimpress-low-life-simulator": [
        {
          "id": "lifesimpress-low-life-simulator-sidebar",
          "name": "工位模拟器",
          "type": "webview"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "lifesimpress.lowLifeSimulator.startDay",
          "when": "view == lifesimpress-low-life-simulator-sidebar",
          "group": "navigation"
        },
        {
          "command": "lifesimpress.lowLifeSimulator.reset",
          "when": "view == lifesimpress-low-life-simulator-sidebar",
          "group": "navigation"
        }
      ]
    }
  },
  "devDependencies": {
    "@vscode/vsce": "^3.9.0"
  }
}
